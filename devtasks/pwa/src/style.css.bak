:root{
  --bg:#050a08;
  --card:rgba(0,255,156,.06);
  --line:rgba(0,255,156,.22);
  --text:#c9ffe9;
  --muted:rgba(201,255,233,.7);
  --green:#00ff9c;
  --red:#ff3b3b;
  --amber:#ffb020;
  --shadow: 0 18px 50px rgba(0,0,0,.55);
  --r: 22px;
}
*{box-sizing:border-box}
html,body{height:100%}
body{
  margin:0;
  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
  color:var(--text);
  background:
    radial-gradient(900px 500px at 20% 10%, rgba(0,255,156,.12), transparent 55%),
    radial-gradient(900px 500px at 80% 0%, rgba(0,255,156,.08), transparent 60%),
    linear-gradient(180deg, #020503, var(--bg));
}
a{color:var(--green)}
.wrap{max-width:900px;margin:0 auto;padding:18px 14px 40px}
.h1{font-size:44px;letter-spacing:.5px;margin:8px 0 4px}
.sub{color:var(--muted);line-height:1.25;margin:0 0 14px}
.card{
  border:1px solid var(--line);
  background:linear-gradient(180deg, rgba(0,255,156,.07), rgba(0,0,0,.2));
  box-shadow:var(--shadow);
  border-radius:var(--r);
  padding:14px;
  backdrop-filter: blur(10px);
}
.row{display:grid;gap:12px}
@media(min-width:760px){.row{grid-template-columns:1fr 1fr}}
.field{display:flex;flex-direction:column;gap:6px}
label{color:var(--muted);font-size:13px}
input,textarea{
  width:100%;
  padding:12px 12px;
  border-radius:16px;
  border:1px solid rgba(0,255,156,.18);
  background:rgba(0,0,0,.35);
  color:var(--text);
  outline:none;
}
textarea{min-height:90px;resize:vertical}
.btns{display:grid;gap:10px;grid-template-columns:1fr 1fr}
.btn{
  border-radius:18px;
  padding:14px 12px;
  border:1px solid rgba(0,255,156,.22);
  background:rgba(0,255,156,.08);
  color:var(--text);
  font-weight:700;
  letter-spacing:.4px;
}
.btn:active{transform:translateY(1px)}
.btn.red{border-color:rgba(255,59,59,.35);background:rgba(255,59,59,.10)}
.btn.ghost{background:rgba(0,0,0,.25)}
.pills{display:flex;flex-wrap:wrap;gap:8px}
.pill{
  padding:10px 12px;border-radius:999px;
  border:1px solid rgba(0,255,156,.18);
  background:rgba(0,0,0,.25);
  color:var(--text);
}
.status{
  display:flex;align-items:center;justify-content:space-between;gap:10px;
  padding:12px;border-radius:18px;border:1px solid rgba(0,255,156,.18);
  background:rgba(0,0,0,.25);
  margin:12px 0;
}
.dot{width:10px;height:10px;border-radius:99px;background:var(--amber)}
.dot.ok{background:var(--green)}
.dot.bad{background:var(--red)}
.log{
  margin-top:12px;
  padding:12px;
  border-radius:18px;
  border:1px solid rgba(0,255,156,.14);
  background:rgba(0,0,0,.3);
  min-height:140px;
  white-space:pre-wrap;
  overflow:auto;
}
.small{font-size:12px;color:var(--muted)}
.loading{opacity:.75;filter:saturate(.8)}

.tabs { display:flex; gap:10px; flex-wrap:wrap; margin: 14px 0; }
.pill { border-radius: 999px; padding: 10px 14px; border: 1px solid rgba(0,255,160,.18); background: rgba(0,0,0,.25); color: rgba(220,255,245,.92); }
.pill-active { border-color: rgba(0,255,160,.55); box-shadow: 0 0 0 2px rgba(0,255,160,.12) inset; }

.metricsRow { display:flex; gap:10px; flex-wrap:wrap; margin: 10px 0 6px; }
.log { max-height: 260px; overflow:auto; }
.btn.tiny { padding: 8px 10px; font-size: 12px; }
